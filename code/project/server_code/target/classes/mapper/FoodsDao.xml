<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cl.dao.FoodsDao">

    <resultMap id="BaseResultMap" type="com.cl.entity.FoodsEntity">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="calory" property="calory"/>
        <result column="weight" property="weight"/>
        <result column="unit" property="unit"/>
        <result column="thumb_image_url" property="thumbImageUrl"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, code, name, calory, weight, unit, thumb_image_url, created_at
    </sql>

    <select id="selectList" parameterType="map" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from foods
        <where>
            <if test="ew.sqlSegment != null">
                ${ew.sqlSegment}
            </if>
        </where>
        <if test="ew.orderByClause != null">
            ${ew.orderByClause}
        </if>
    </select>

</mapper>
