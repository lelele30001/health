<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cl.dao.StoreupDao">
    <resultMap id="storeupResultMap" type="com.cl.entity.StoreupEntity">
        <id column="id" property="id"/>
        <result column="addtime" property="addtime"/>
        <result column="refid" property="refid"/>
        <result column="tablename" property="tablename"/>
        <result column="name" property="name"/>
        <result column="picture" property="picture"/>
        <result column="type" property="type"/>
        <result column="inteltype" property="inteltype"/>
        <result column="remark" property="remark"/>
        <result column="userid" property="userid"/>
    </resultMap>

    <resultMap id="storeupViewResultMap" type="com.cl.entity.view.StoreupView" extends="storeupResultMap">
    </resultMap>

    <select id="selectListView" resultMap="storeupViewResultMap">
        SELECT * FROM storeup
        <where>
            ${ew.sqlSegment}
        </where>
    </select>

    <select id="selectListView" parameterType="com.baomidou.mybatisplus.plugins.pagination.Pagination" resultMap="storeupViewResultMap">
        SELECT * FROM storeup
        <where>
            ${ew.sqlSegment}
        </where>
    </select>

    <select id="selectView" resultMap="storeupViewResultMap">
        SELECT * FROM storeup
        <where>
            ${ew.sqlSegment}
        </where>
        LIMIT 1
    </select>

</mapper>