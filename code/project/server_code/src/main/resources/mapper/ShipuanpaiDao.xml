<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.ShipuanpaiDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.ShipuanpaiEntity" id="shipuanpaiMap">
        <result property="riqi" column="riqi"/>
        <result property="shipumingcheng" column="shipumingcheng"/>
        <result property="fengmian" column="fengmian"/>
        <result property="xiangqing" column="xiangqing"/>
        <result property="storeupNumber" column="storeup_number"/>
    </resultMap>

    <select id="selectListView"
            resultType="com.cl.entity.view.ShipuanpaiView">

        SELECT shipuanpai.* FROM shipuanpai shipuanpai
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectView"
            resultType="com.cl.entity.view.ShipuanpaiView">
        SELECT * FROM shipuanpai shipuanpai
        <where>1=1 ${ew.sqlSegment}</where>
    </select>


</mapper>
